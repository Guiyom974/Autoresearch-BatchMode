# ===========================================================================
# AutoResearch - Environment Configuration
# Copy this file to .env and fill in your settings.
# ===========================================================================

# ---------------------------------------------------------------------------
# CLOUD API — pick ONE provider and uncomment those two lines
# ---------------------------------------------------------------------------

# --- Option 1: Poe (https://poe.com/api_key) ---
# Web-Search model gives live internet search results.
CLOUD_API_KEY=your_poe_api_key_here
CLOUD_BASE_URL=https://api.poe.com/v1

# --- Option 2: OpenRouter (https://openrouter.ai/keys) ---
# Use any model on OpenRouter. For web search, pick a model with browsing
# (e.g. perplexity/sonar-pro). Most models won't do live search.
# CLOUD_API_KEY=sk-or-your_openrouter_key_here
# CLOUD_BASE_URL=https://openrouter.ai/api/v1

# --- Option 3: Any other OpenAI-compatible endpoint ---
# CLOUD_API_KEY=your_key_here
# CLOUD_BASE_URL=https://your-endpoint.com/v1

# ---------------------------------------------------------------------------
# LOCAL OLLAMA (optional — only needed if you select Ollama backend)
# Default points to a local Ollama instance. Change if running remotely.
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ---------------------------------------------------------------------------
# MODEL NAMES — override defaults for cloud tasks
# Defaults shown. Only set these if you want different models.
# ---------------------------------------------------------------------------

# Web Search model (needs live internet access — works out of the box on Poe)
# CLOUD_MODEL_WEBSEARCH=Web-Search

# Hypothesis formulation model (default used when you pick Cloud in the menu)
# CLOUD_MODEL_RESEARCH=Gemini-3.1-Flash-Lite

# Problem reformulation model (used between breakthrough iterations)
# CLOUD_MODEL_REFORMULATE=Gemini-3.1-Pro

# ---------------------------------------------------------------------------
# CONTEXT ASSESSMENT MODEL (Ollama only)
# Used to screen past experiments for relevance before each run.
# Must be an Ollama model. Set to any model you have pulled locally.
# ---------------------------------------------------------------------------
# CONTEXT_ASSESSMENT_MODEL=llama3.2:latest
